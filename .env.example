# ============================================================
# Azure Cost Dashboard - Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in the values.
# ============================================================

# .NET Core Backend API URL (leave empty to use mock data)
VITE_API_URL=http://localhost:5038/api

# Set to "true" to force mock data even when API URL is configured
VITE_USE_MOCK_DATA=false

# Application version and environment (shown in footer/navbar)
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=DEV
